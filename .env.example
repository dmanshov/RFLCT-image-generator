# ── RFLCT Image Generator – omgevingsvariabelen ──────────────────────────────
# Kopieer dit bestand naar `.env.local` en vul je sleutels in.
# `.env.local` wordt NIET gecommit (zie .gitignore).

# Google Gemini – voor het genereren en herfotograferen van de beelden.
# Verkrijg een sleutel via https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# (optioneel) Welk Gemini-beeldmodel gebruikt wordt.
# Standaard: gemini-3.1-flash-image-preview  (Nano Banana 2).
# Premium alternatief: gemini-3-pro-image-preview  (Nano Banana Pro).
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview

# (optioneel) Fallback-beeldmodel als het hoofdmodel niet beschikbaar is.
# Standaard: gemini-2.5-flash-image  (legacy "Nano Banana").
GEMINI_IMAGE_MODEL_FALLBACK=gemini-2.5-flash-image

# (optioneel) Tekstmodel voor de prompt-rewriting-stap (verrijkt de prompt
# vóór de beeldgeneratie). Standaard: gemini-2.5-flash
GEMINI_TEXT_MODEL=gemini-2.5-flash

# (optioneel) Beeldgrootte: "1K", "2K" of "4K". Standaard: 2K
GEMINI_IMAGE_SIZE=2K

# Anthropic Claude – voor het schrijven van de caption + toelichting.
# Verkrijg een sleutel via https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# (optioneel) Welk Claude-model gebruikt wordt voor de caption.
# Standaard: claude-sonnet-4-6
ANTHROPIC_MODEL=claude-sonnet-4-6

# Login – het wachtwoord om toegang te krijgen tot de app.
# Zonder dit wachtwoord kan niemand inloggen of beelden genereren.
# Kies een sterk, uniek wachtwoord en stel het ook in bij Vercel.
APP_PASSWORD=

# Database (Vercel Postgres / Neon) – om je instellingen te bewaren.
# Wordt normaal automatisch gezet door de Vercel/Neon-integratie.
# Lokaal kan je de pooled connection string uit Neon hier plakken.
DATABASE_URL=
